@model UserPlaylist
@{
    ViewData["Title"] = "Delete Playlist";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Delete playlist</h1>
<p class="page-lead">Confirm removal of this playlist and its song links.</p>

<section class="detail-card">
    <dl class="detail-grid">
        <dt>Name</dt>
        <dd>@Model.Name</dd>

        <dt>Owner</dt>
        <dd>@Model.OwnerUserName</dd>

        <dt>Created at</dt>
        <dd>@Model.CreatedAt.ToString("g")</dd>

        <dt>Public</dt>
        <dd>@Model.IsPublic</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-stack">
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
