@model PlaylistIndexViewModel
@{
    ViewData["Title"] = "Playlists";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Playlists</h1>
<p class="page-lead">A small demo page built from the new playlist EF model.</p>

<div class="form-actions mb-3">
    <a class="btn btn-primary" asp-controller="Playlist" asp-action="Create">Create playlist</a>
</div>

<div class="table-wrap">
    <table class="metal-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Owner</th>
                <th>Songs</th>
                <th>Likes</th>
                <th>Visibility</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Playlists.Count == 0)
            {
                <tr>
                    <td colspan="6">No playlists available.</td>
                </tr>
            }
            else
            {
                @foreach (var playlist in Model.Playlists)
                {
                    <tr>
                        <td>@playlist.Name</td>
                        <td>@playlist.OwnerUserName</td>
                        <td>@(playlist.PlaylistSongs?.Count ?? 0)</td>
                        <td>@playlist.Likes</td>
                        <td>@(playlist.IsPublic ? "Public" : "Private")</td>
                        <td>@playlist.CreatedAt.ToString("yyyy-MM-dd")</td>
                    </tr>
                    <tr>
                        <td colspan="6">
                            <div class="form-actions mb-2">
                                <a class="inline-link" asp-controller="Playlist" asp-action="Edit" asp-route-id="@playlist.Id">Edit</a>
                                <a class="inline-link" asp-controller="Playlist" asp-action="Delete" asp-route-id="@playlist.Id">Delete</a>
                            </div>
                            <div class="playlist-tracklist">
                                @foreach (var track in (playlist.PlaylistSongs ?? Enumerable.Empty<Riffdle.Models.Domain.PlaylistSong>()).OrderBy(item => item.AddedAt))
                                {
                                    <span class="guess-badge">@(track.Song?.Title ?? "Unknown track")</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>