@model PlaylistFormViewModel
@{
    ViewData["Title"] = "Edit Playlist";
}

@functions {
    private static string RelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalDays >= 2)
            return $"added {(int)span.TotalDays} days ago";
        if (span.TotalDays >= 1)
            return "added 1 day ago";
        if (span.TotalHours >= 1)
            return $"added {(int)span.TotalHours} hours ago";
        if (span.TotalMinutes >= 1)
            return $"added {(int)span.TotalMinutes} minutes ago";
        return "added just now";
    }
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Edit playlist</h1>
<p class="page-lead">Update playlist metadata without changing its original creation time.</p>

<section class="detail-card">
    <form asp-action="Edit" method="post" class="form-stack">
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="OwnerUserName" class="form-label"></label>
            <input asp-for="OwnerUserName" class="form-control" />
            <span asp-validation-for="OwnerUserName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsPublic" class="form-check-input" />
            <label asp-for="IsPublic" class="form-check-label"></label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

<section class="detail-card">
    <h2 class="section-title">Add songs</h2>
    @if (Model.AvailableSongs.Count == 0)
    {
        <p class="page-lead mb-0">All songs are already part of this playlist.</p>
    }
    else
    {
        <form asp-action="AddSong" asp-route-id="@Model.Id" method="post" class="playlist-song-form">
            @Html.AntiForgeryToken()
            <label for="songId" class="form-label">Song</label>
            <div class="playlist-song-row">
                <select id="songId" name="songId" class="form-select">
                    <option value="">Choose a song</option>
                    @foreach (var song in Model.AvailableSongs)
                    {
                        <option value="@song.Id">@song.Title - @(song.Album?.Band?.Name ?? "Unknown band") / @(song.Album?.Title ?? "Unknown album")</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary">Add song</button>
            </div>

            @* Removing client-editable date control. Server will set AddedAt to UTC now. *@
        </form>
    }

    @if (Model.PlaylistSongs.Count > 0)
    {
        <div class="playlist-tracklist mt-3">
            @foreach (var track in Model.PlaylistSongs.OrderBy(item => item.AddedAt))
            {
                <div class="playlist-track-item">
                    <span class="guess-badge">
                        @(track.Song?.Title ?? "Unknown track")
                        <time class="track-added-at" datetime="@track.AddedAt.ToString("o")">@track.AddedAt.ToLocalTime().ToString("g")</time>
                    </span>
                    <form asp-action="RemoveSong" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="songId" value="@track.SongId" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Remove</button>
                    </form>
                </div>
            }
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
