@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;

    string SidebarLinkClass(string controller)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "sidebar-link active"
            : "sidebar-link";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Riffdle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Metal+Mania&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar" aria-label="Primary navigation">
            <div class="brand-block">
                <a class="brand-title" asp-controller="Home" asp-action="Index">Riffdle</a>
                <p class="brand-subtitle">Metal music quiz</p>
            </div>

            <nav class="sidebar-nav">
                <a class="@SidebarLinkClass("Home")" asp-controller="Home" asp-action="Index">Home</a>
                <a class="@SidebarLinkClass("Band")" asp-controller="Band" asp-action="Index">Bands</a>
                <a class="@SidebarLinkClass("Album")" asp-controller="Album" asp-action="Index">Albums</a>
                <a class="@SidebarLinkClass("Song")" asp-controller="Song" asp-action="Index">Songs</a>
                <a class="@SidebarLinkClass("Genre")" asp-controller="Genre" asp-action="Index">Genres</a>
                <a class="@SidebarLinkClass("Playlist")" asp-controller="Playlist" asp-action="Index">Playlists</a>
            </nav>

            <div class="sidebar-streak">
                <span class="mini-label">Daily Streak</span>
                <strong>@(ViewData["DailyStreak"] ?? 6) days</strong>
            </div>
        </aside>

        <div class="content-shell">
            <div class="breadcrumbs-slot">
                @RenderSection("Breadcrumbs", required: false)
            </div>

            <main class="main-content" role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/autocomplete.js" asp-append-version="true"></script>
    <script src="~/js/datepicker.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
