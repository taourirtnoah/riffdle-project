@model Genre
@{
    ViewData["Title"] = "Delete Genre";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Delete genre</h1>
<p class="page-lead">Confirm removal of this genre from the catalog.</p>

<section class="detail-card">
    <dl class="detail-grid">
        <dt>Name</dt>
        <dd>@Model.Name</dd>

        <dt>Description</dt>
        <dd>@Model.Description</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-stack">
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</section>
