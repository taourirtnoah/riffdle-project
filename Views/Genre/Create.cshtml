@model GenreFormViewModel
@{
    ViewData["Title"] = "Create Genre";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Create genre</h1>
<p class="page-lead">Add a genre label and description for the catalog.</p>

<section class="detail-card">
    <form asp-action="Create" method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
