@model AlbumIndexViewModel
@{
    ViewData["Title"] = "Albums";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Albums</h1>
<p class="page-lead">Dig through landmark releases and jump into their full track listings.</p>

<div class="form-actions mb-3">
    <a class="btn btn-primary" asp-controller="Album" asp-action="Create">Create album</a>
</div>

<div class="table-wrap">
    <table class="metal-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Band</th>
                <th>Year</th>
                <th>Songs</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Albums.Count == 0)
            {
                <tr>
                    <td colspan="5">No albums available.</td>
                </tr>
            }
            else
            {
                @foreach (var album in Model.Albums.OrderBy(item => item.ReleaseYear))
                {
                    <tr>
                        <td>@album.Title</td>
                        <td>@(album.Band?.Name ?? "Unknown")</td>
                        <td>@album.ReleaseYear</td>
                        <td>@(album.Songs?.Count ?? 0)</td>
                        <td>
                            <a class="inline-link" asp-controller="Album" asp-action="Details" asp-route-id="@album.Id">View details</a>
                            <a class="inline-link" asp-controller="Album" asp-action="Edit" asp-route-id="@album.Id">Edit</a>
                            <a class="inline-link" asp-controller="Album" asp-action="Delete" asp-route-id="@album.Id">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
