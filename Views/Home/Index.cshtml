@model DailyQuizViewModel
@{
    ViewData["Title"] = "Daily Quiz";
    var song = Model.DailySong;
    var streak = ViewData["DailyStreak"] as int? ?? 6;
}

<section class="quiz-hero">
    <p class="eyebrow">Daily Challenge</p>
    <h1 class="page-title">Guess today's metal song</h1>
    <p class="page-lead">One hidden track. Four clues. You get smarter with every miss.</p>

    <div class="hero-grid">
        <div class="art-placeholder" aria-hidden="true">
            <div class="art-noise"></div>
            <span>Obscured waveform / album art</span>
        </div>

        <aside class="streak-card">
            <p class="mini-label">Current streak</p>
            <p class="streak-value">@streak days</p>
            <button type="button" 
                    id="share-result-btn"
                    class="metal-button metal-button-ghost"
                    data-is-completed="@(Model.ShouldShowResult ? "true" : "false")"
                    data-is-correct="@(Model.IsCorrect ? "true" : "false")"
                    data-attempt-count="@Model.AttemptCount">
                Share Today's Result
            </button>
        </aside>
    </div>

    <section class="quiz-panel">
        <h2 class="section-title">Clues</h2>
        <ul class="clue-list">
            <li class="@(Model.AttemptCount >= 1 ? "revealed" : "locked")">
                <span>Album year</span>
                <strong>@(Model.AttemptCount >= 1 ? Model.AlbumYear.ToString() : "Locked")</strong>
            </li>
            <li class="@(Model.AttemptCount >= 2 ? "revealed" : "locked")">
                <span>First lyric</span>
                <strong>@(Model.AttemptCount >= 2 ? Model.FirstLyric : "Locked")</strong>
            </li>
            <li class="@(Model.AttemptCount >= 3 ? "revealed" : "locked")">
                <span>Genre</span>
                <strong>@(Model.AttemptCount >= 3 ? Model.GenreName : "Locked")</strong>
            </li>
            <li class="@(Model.AttemptCount >= 4 ? "revealed" : "locked")">
                <span>Band initials</span>
                <strong>@(Model.AttemptCount >= 4 ? Model.BandInitials : "Locked")</strong>
            </li>
        </ul>

        <form asp-controller="Home" asp-action="Index" method="post" class="quiz-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="attemptCount" value="@Model.AttemptCount" />
            <input type="hidden" name="previousGuesses" value="@string.Join("|", Model.PreviousGuesses)" />

            <label for="guess" class="mini-label">Your guess</label>
            <div class="guess-row">
                <div class="guess-input-wrap">
                    <input id="guess"
                           name="guess"
                           class="guess-input"
                           type="text"
                           value=""
                           placeholder="Enter song title"
                           autocomplete="off" />
                    <ul id="guess-suggestions" class="guess-suggestions" role="listbox" aria-label="Song suggestions"></ul>
                </div>
                <button type="submit" class="metal-button">Submit Guess</button>
            </div>
        </form>

        <script id="available-song-titles" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableSongs))</script>

    @if (Model.GuessHistory.Count > 0)
    {
        <section class="guess-history-container">
            <h3 class="section-title">Your guesses</h3>
            <div class="guess-history-list">
                @foreach (var entry in Model.GuessHistory)
                {
                    var badgeClass = entry.Outcome switch
                    {
                        GuessOutcome.Correct => "correct",
                        GuessOutcome.SameBand => "same-band",
                        _ => "incorrect"
                    };

                    <span class="guess-badge @badgeClass">@entry.Guess</span>
                }
            </div>
        </section>
    }
    </section>

    @if (Model.ShouldShowResult && song is not null)
    {
        <section class="result-panel @(Model.IsCorrect ? "result-correct" : "result-wrong")">
            <h2 class="section-title">Result</h2>
            <p>@Model.FeedbackMessage</p>

            <div class="result-grid">
                <div class="album-cover-placeholder" aria-hidden="true">
                    <span>@(song.Album?.Title ?? "Unknown")</span>
                </div>

                <dl class="detail-grid">
                    <dt>Correct answer</dt>
                    <dd>@(song.Title ?? "Unknown")</dd>

                    <dt>Band</dt>
                    <dd>@(song.Album?.Band?.Name ?? "Unknown")</dd>

                    <dt>Album</dt>
                    <dd>@(song.Album?.Title ?? "Unknown") (@(song.Album?.ReleaseYear.ToString() ?? ""))</dd>

                    <dt>Genre</dt>
                    <dd><span class="genre-badge">@(song.Album?.Band?.Genre?.Name ?? "Unknown")</span></dd>
                </dl>
            </div>

            <a class="inline-link" asp-controller="Song" asp-action="Details" asp-route-id="@song.Id">Open song details</a>

            <form asp-controller="Home" asp-action="PlayAgain" method="post" class="play-again-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="metal-button">Play Again</button>
            </form>
        </section>
    }
</section>
