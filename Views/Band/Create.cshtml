@model BandFormViewModel
@{
    ViewData["Title"] = "Create Band";
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

<h1 class="page-title">Create band</h1>
<p class="page-lead">Add a band profile to power album and genre navigation.</p>

<section class="detail-card">
    <form asp-action="Create" method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FormedYear" class="form-label"></label>
            <input asp-for="FormedYear" class="form-control" />
            <span asp-validation-for="FormedYear" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Country" class="form-label"></label>
            <input asp-for="Country" class="form-control" />
            <span asp-validation-for="Country" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        @await Html.PartialAsync("_AutocompleteDropdown", new AutocompleteDropdownViewModel
        {
            Label = "Genre",
            InputName = "GenreSearch",
            InputId = "GenreSearch",
            HiddenName = nameof(Model.GenreId),
            HiddenId = nameof(Model.GenreId),
            SelectedId = Model.GenreId == 0 ? null : Model.GenreId,
            SelectedText = string.Empty,
            SearchUrl = Url.Action("Genres", "Search") ?? string.Empty,
            Placeholder = "Search genres"
        })
        <span asp-validation-for="GenreId" class="text-danger"></span>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
