@model BandDetailsViewModel
@{
    ViewData["Title"] = "Band Details";
    var band = Model.Band;
}

@section Breadcrumbs {
    @await Html.PartialAsync("_Breadcrumbs")
}

@if (band is null)
{
    <h1 class="page-title">Band not found</h1>
    <p class="page-lead">The requested band does not exist in the mock repository.</p>
}
else
{
    <h1 class="page-title">@band.Name</h1>

    <div class="form-actions mb-3">
        <a class="btn btn-primary" asp-controller="Band" asp-action="Edit" asp-route-id="@band.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-controller="Band" asp-action="Delete" asp-route-id="@band.Id">Delete</a>
    </div>

    <section class="detail-card">
        <dl class="detail-grid">
            <dt>Country</dt>
            <dd>@band.Country</dd>

            <dt>Formed year</dt>
            <dd>@band.FormedYear</dd>

            <dt>Primary genre</dt>
            <dd><span class="genre-badge">@(band.Genre?.Name ?? "Unknown")</span></dd>

            <dt>Description</dt>
            <dd>@band.Description</dd>
        </dl>
    </section>

    <section class="detail-card">
        <h2 class="section-title">Albums</h2>

        <div class="table-wrap">
            <table class="metal-table metal-table-compact">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Release year</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var album in (band.Albums ?? Enumerable.Empty<Riffdle.Models.Domain.Album>()).OrderBy(item => item.ReleaseYear))
                    {
                        <tr>
                            <td>@album.Title</td>
                            <td>@album.ReleaseYear</td>
                            <td>
                                <a class="inline-link" asp-controller="Album" asp-action="Details" asp-route-id="@album.Id">View details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <a class="inline-link" asp-controller="Band" asp-action="Index">&larr; Back to list</a>
}
